{
  "manifest_version": 3,
  "name": "ResumeAI",
  "version": "2.0.0",
  "description": "AI-powered resume tailoring. Reads the job description on any page and rewrites your resume to match it — powered by Claude.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ResumeAI – Tailor your resume"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "host_permissions": [
    "https://*.vercel.app/*"
  ]
}